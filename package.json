{
  "name": "riscv-language-support",
  "displayName": "RiscV Language Support",
  "description": "RiscV Language Support for Visual Studio Code",
  "version": "0.0.1",
  "publisher": "Tao Liu",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
     "onLanguage:riscvasm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "riscvasm",
        "aliases": ["riscvasm", "RiscV Assembly"],
        "extensions": [".rv.s"],
        "filenames": ["*.rv.s"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-server": "cargo build --manifest-path ./server/Cargo.toml",
    "build-server-release": "cargo build --release --manifest-path ./server/Cargo.toml"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.3"
  }
}
