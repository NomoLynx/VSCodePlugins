{
  "name": "riscv-language-support",
  "displayName": "RiscV Language Support",
  "description": "RiscV Language Support for Visual Studio Code",
  "version": "0.0.1",
  "publisher": "tao-liu",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:riscvasm"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "riscvasm",
        "aliases": [
          "riscvasm",
          "RiscV Assembly"
        ],
        "extensions": [
          ".rv.s"
        ],
        "filenames": [
          "*.rv.s"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "instruction",
        "superType": "keyword",
        "description": "RISC-V instruction mnemonic"
      },
      {
        "id": "instructionCallRet",
        "superType": "instruction",
        "description": "RISC-V call/ret instruction mnemonic"
      },
      {
        "id": "registerOrdinary",
        "superType": "variable",
        "description": "RISC-V ordinary integer register"
      },
      {
        "id": "registerFloat",
        "superType": "variable",
        "description": "RISC-V floating-point register"
      },
      {
        "id": "registerVector",
        "superType": "variable",
        "description": "RISC-V vector register"
      },
      {
        "id": "immediate",
        "superType": "number",
        "description": "RISC-V immediate value"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "riscvasm",
        "scopes": {
          "instruction": [
            "keyword.control.assembly"
          ],
          "instructionCallRet": [
            "keyword.control.call-return.assembly",
            "keyword.control.flow.assembly"
          ],
          "registerOrdinary": [
            "variable.language.register.integer.assembly",
            "variable.language.register.assembly"
          ],
          "registerFloat": [
            "variable.language.register.float.assembly",
            "variable.language.register.assembly"
          ],
          "registerVector": [
            "variable.language.register.vector.assembly",
            "variable.language.register.assembly"
          ],
          "immediate": [
            "constant.numeric.assembly"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[riscvasm]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "instructionCallRet:riscvasm": {
            "foreground": "#FF4FA3"
          },
          "registerFloat:riscvasm": {
            "foreground": "#0d4acd"
          },
          "registerOrdinary:riscvasm": {
            "foreground": "#2D6CDF"
          },
          "registerVector:riscvasm": {
            "foreground": "#4B9CFF"
          },
          "immediate:riscvasm": {
            "foreground": "#9B59B6"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-server": "cargo build --manifest-path ./server/Cargo.toml",
    "build-server-release": "cargo build --release --manifest-path ./server/Cargo.toml"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.3"
  }
}
