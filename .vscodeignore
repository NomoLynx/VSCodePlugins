# source code (you only need compiled output)
src/**
**/*.ts

# dev stuff
.vscode/**
.git/**
.gitignore

# ⚠️ DO NOT exclude node_modules (you need runtime deps)
# node_modules/**   <-- REMOVE THIS LINE

# build junk
target/**
out/test/**
coverage/**

# docs (optional)
*.md
!README.md

# config files you don't need
tsconfig.json
.eslintrc*

# remove Rust source
server/src/**
server/Cargo.*

# exclude everything in target
server/target/**

# include ONLY the release binary
!server/target/release/
!server/target/release/rust_keyword_lsp_server.exe

# exclude *.vsix on the root folder
*.vsix

# exclude .github folder on the root folder
.github/

# exclude logs folder under server
server/logs/

# exclude VSCodePlugins.code-workspace file on the root folder
VSCodePlugins.code-workspace

# remove extra icon
icon2.png